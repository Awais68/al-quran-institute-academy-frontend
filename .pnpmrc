# pnpm configuration to help prevent webpack module loading errors

# Use symlinks instead of hard links (more reliable on some systems)
symlink=true

# Strict peer dependencies to avoid version conflicts
strict-peer-dependencies=false

# Auto-install peers
auto-install-peers=true

# Prefer frozen lockfile in CI
# frozen-lockfile=true

# Cache directory (default is fine, but explicit for clarity)
# store-dir=~/.pnpm-store

# Enable hoisting to reduce module resolution issues
shamefully-hoist=false
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=@babel/*

# Side effects cache
side-effects-cache=true
